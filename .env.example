# ============================================================
# NexusCockpit Environment Configuration (SHARED — Backend)
# ------------------------------------------------------------
# 此文件位于项目根目录 NexusCockpit/.env
# 后端代码在 backend_code/ 中，通过 config.py 自动定位此文件。
# 所有相对路径基于项目根目录 NexusCockpit/ 解析。
#
# 前端配置在 fronted_code/.env.local 中，独立管理。
#
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM / Embedding (OpenAI 兼容, 改 base_url 即可切换供应商) ---
# 硅基流动 (默认推荐): ARK_BASE_URL=https://api.siliconflow.cn/v1  (免费 embedding/rerank)
# 火山方舟 (备选):     ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 申请链接: 硅基流动 https://cloud.siliconflow.cn/account/ak | 火山方舟 https://console.volcengine.com/ark
ARK_API_KEY=your_api_key_here
ARK_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560
# ⚠️ 切换 embedding 模型时 EMBEDDING_DIM 必须同步改, 并重建 Milvus collection:
#   硅基流动 BAAI/bge-m3 → EMBEDDING_DIM=1024
#   硅基流动 Qwen/Qwen3-Embedding-4B → EMBEDDING_DIM=2560 (当前)

# --- Milvus (Vector Store) ---
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_COLLECTION_FOOD=Food_List
MILVUS_COLLECTION_MEMORY=User_Memory

# --- Neo4j (Knowledge Graph) ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuscockpit

# --- Redis (Cache + Rate Limit + PubSub) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_PASSWORD=
REDIS_DB=0

# --- RabbitMQ (Task Queue) ---
# v2.2 简化: RabbitMQ/Celery 已移除（未落地），任务队列改为 asyncio.create_task()
# RABBITMQ_HOST=127.0.0.1
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# --- Tavily (Web Search) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Langfuse (Tracing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- JWT Auth ---
JWT_SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Vehicle Bus ---
VEHICLE_ADAPTER=mock
# VEHICLE_ADAPTER=http  # for real vehicle API

# --- 高德地图逆地理编码 (可选，提升 GPS 定位精度) ---
# 申请: https://lbs.amap.com/api/webservice/guide/create-project/get-key
# 不填则降级到 Nominatim + IP 定位
AMAP_KEY=
# VEHICLE_API_BASE_URL=http://localhost:8080
# VEHICLE_MCP_COMMAND=python
# VEHICLE_MCP_ARGS=vehicle_mcp_server.py

# --- ASR / TTS / SV Model Paths (RELATIVE to project root) ---
# Download models first, see docs/deployment/SETUP.md for instructions
FUNASR_MODEL_PATH=./models/asr/sensevoice
CAM_MODEL_PATH=./models/sv/cam_plus
COSYVOICE_MODEL_PATH=./models/tts/cosyvoice
# v2.2 简化: LOCAL_LLM_MODEL_PATH/USE_LOCAL_LLM 旧占位已移除
# 改为 LLM_FALLBACK_* 配置，详见下方降级配置

# --- Speaker Verification Audio (RELATIVE to project root) ---
SPEAKER_ENROLL_DIR=./assets/speaker/enroll_wav
SPEAKER_USERS_DIR=./assets/speaker/users

# --- Data Directories (RELATIVE to project root) ---
FOOD_DATA_DIR=./data/food
KNOWLEDGE_DATA_DIR=./data/knowledge
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/temp
# v2.2 新增: 用户偏好数据目录（声纹识别后存储用户偏好）
PREFERENCES_DIR=./data/preferences

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# --- Semantic Cache ---
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600

# --- v2.1.2: LLM Call Optimization (reduce rate limiting on free APIs) ---
# Reflection: disable to save 1 LLM call per message
REFLECTION_ENABLED=true
# Memory Extraction: disable to save 1-2 LLM calls per message
MEMORY_EXTRACTION_ENABLED=true


# --- Alibaba OSS (Object Storage) ---
# v2.2 简化: OSS 配置已移除（未集成，过度设计）
# 如需对象存储，可参考 docs/architecture/ 中的存储方案设计
# OSS_ACCESS_KEY=your_oss_access_key_here
# OSS_SECRET_KEY=your_oss_secret_key_here
# OSS_BUCKET_NAME=your_bucket_name
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_REGION=cn-beijing
# OSS_PUBLIC_BASE_URL=https://your_bucket_name.oss-cn-beijing.aliyuncs.com

# ============================================================
# 双模式部署开关 (local=本地Docker | cloud=云端托管)
# 切换线上时改 provider 为 cloud 并填下方云端 AK/SK, 代码无需改动
# ============================================================
VECTOR_STORE_PROVIDER=local      # local=本地Milvus | cloud=Zilliz Cloud
GRAPH_STORE_PROVIDER=local       # local=本地Neo4j | cloud=AuraDB
CACHE_PROVIDER=local             # local=本地Redis | cloud=云Redis
RERANKER_PROVIDER=local          # local=本地BGE | cloud=硅基流动Rerank | none=跳过

# --- Zilliz Cloud (VECTOR_STORE_PROVIDER=cloud 时填) ---
# MILVUS_URI=https://<your-cluster>.zillizcloud.com
# MILVUS_TOKEN=<zilliz api key>

# --- Neo4j AuraDB (GRAPH_STORE_PROVIDER=cloud 时填) ---
# NEO4J_URI=neo4j+s://<your-db-id>.databases.neo4j.io
# NEO4J_PASSWORD=<aura password>

# --- 云 Redis (CACHE_PROVIDER=cloud 时填) ---
# REDIS_HOST=<cloud redis host>
# REDIS_PORT=<port>
# REDIS_PASSWORD=<cloud redis password>
# 注意: 云 Redis 若无 RediSearch 模块, 语义缓存自动降级为 scan 模式

# --- 硅基流动 Rerank (RERANKER_PROVIDER=cloud 时填, 复用 ARK_API_KEY/ARK_BASE_URL) ---
# RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ============================================================
# v2.1 多座舱配置
# ============================================================
# v2.2 简化: 默认单座舱模式，SubAgent/MainAgent 配置已移除
COCKPIT_COUNT=1
# COCKPIT_ISOLATION_MODE=shared          # v2.2 已移除（单座舱无需隔离）
# SUBAGENT_CHECK_MIN=30                   # v2.2 已移除
# SUBAGENT_CHECK_MAX=60                   # v2.2 已移除
# MAINAGENT_CONFIRM_ENABLED=true          # v2.2 已移除
# SUBAGENT_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct  # v2.2 已移除

# --- v2.1 Go 网关配置 ---
NEXUS_GATE_HOST=0.0.0.0
NEXUS_GATE_PORT=8080
NEXUS_AI_HOST=127.0.0.1
NEXUS_AI_PORT=8000
NEXUS_GATE_MODE=proxy                  # v2.2: 固定 proxy（grpc 未实现已移除）
JWT_SECRET=nexus-cockpit-v2.1
JWT_EXPIRE_HOURS=24

# --- v2.1 RBAC 配置 ---
RBAC_DEFAULT_ROLE=cockpit_user
RBAC_ADMIN_USERNAME=admin

# --- v2.1 声纹配置 ---
VOICEPRINT_MODEL=cam_plus
VOICEPRINT_THRESHOLD=0.7
VOICEPRINT_ENROLL_COUNT=3

# ============================================================
# v2.2 新增: LLM 本地降级配置（llama.cpp OpenAI 兼容接口）
# 云端 LLM 不可用时自动降级到本地 Qwen3.5-4B 模型
# 详见 docs/deployment/LLM_FALLBACK.md
# ============================================================
LLM_FALLBACK_ENABLED=false              # 是否启用本地降级（需先下载模型）
LLM_FALLBACK_BASE_URL=http://127.0.0.1:8082/v1  # llama.cpp 默认地址
LLM_FALLBACK_MODEL=qwen3.5-4b-local    # 本地模型别名
LLM_FALLBACK_API_KEY=                   # llama.cpp 默认无需 API Key
LLM_FALLBACK_TIMEOUT=60                 # 本地 LLM 超时秒数

# --- 降级行为控制 ---
DEGRADATION_NOTIFY_USER=true            # 降级时是否通知用户
DEGRADATION_NOTIFY_ADMIN=true           # 降级时是否通知管理员
