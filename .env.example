# ============================================================
# NexusCockpit Environment Configuration (SHARED — Backend)
# ------------------------------------------------------------
# 此文件位于项目根目录 NexusCockpit/.env
# 后端代码在 backend_code/ 中，通过 config.py 自动定位此文件。
# 所有相对路径基于项目根目录 NexusCockpit/ 解析。
#
# 前端配置在 fronted_code/.env.local 中，独立管理。
#
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM (Ark / Volcengine) ---
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560

# --- Milvus (Vector Store) ---
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_COLLECTION_FOOD=Food_List
MILVUS_COLLECTION_MEMORY=User_Memory

# --- Neo4j (Knowledge Graph) ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuscockpit

# --- Redis (Cache + Rate Limit + PubSub) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- RabbitMQ (Task Queue) ---
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- MySQL (User Data + Audit Log) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=nexuscockpit
MYSQL_DATABASE=nexus_cockpit

# --- Tavily (Web Search) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Langfuse (Tracing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- JWT Auth ---
JWT_SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Vehicle Bus ---
VEHICLE_ADAPTER=mock
# VEHICLE_ADAPTER=http  # for real vehicle API
# VEHICLE_API_BASE_URL=http://localhost:8080
# VEHICLE_MCP_COMMAND=python
# VEHICLE_MCP_ARGS=vehicle_mcp_server.py

# --- ASR / TTS / SV Model Paths (RELATIVE to project root) ---
# Download models first, see docs/deployment/SETUP.md for instructions
FUNASR_MODEL_PATH=./models/asr/sensevoice
CAM_MODEL_PATH=./models/sv/cam_plus
COSYVOICE_MODEL_PATH=./models/tts/cosyvoice
LOCAL_LLM_MODEL_PATH=./models/llm/qwen
USE_LOCAL_LLM=false

# --- Speaker Verification Audio (RELATIVE to project root) ---
SPEAKER_ENROLL_DIR=./assets/speaker/enroll_wav
SPEAKER_USERS_DIR=./assets/speaker/users

# --- Data Directories (RELATIVE to project root) ---
FOOD_DATA_DIR=./data/food
KNOWLEDGE_DATA_DIR=./data/knowledge
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/temp

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# --- Semantic Cache ---
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600


# --- Alibaba OSS (Object Storage) ---
OSS_ACCESS_KEY=your_oss_access_key_here
OSS_SECRET_KEY=your_oss_secret_key_here
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
# Public read base URL (for accessing uploaded files)
OSS_PUBLIC_BASE_URL=https://your_bucket_name.oss-cn-beijing.aliyuncs.com
