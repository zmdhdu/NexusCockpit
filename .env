# ============================================================
# NexusCockpit 环境配置模板 (.env)
# ============================================================
# 此文件是模板/备份文件，不会被代码直接加载。
#
# 实际使用的配置文件:
#   - .env.local  → 本地开发环境 (默认加载)
#   - .env.prod   → 线上生产环境 (APP_ENV=prod 时加载)
#
# 快速开始:
#   cp .env .env.local   然后填入你的密钥
#   cp .env .env.prod    然后填入生产环境密钥
# ============================================================

# ============================================================
# 🔑 需要申请的 API Key / AK/SK 清单
# ============================================================
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │ 1. ARK_API_KEY  (必须申请)                                          │
# │    平台: 硅基流动 (SiliconFlow)                                      │
# │    链接: https://cloud.siliconflow.cn/account/ak                    │
# │    用途: LLM 对话、Embedding 向量化、Rerank 重排                      │
# │    说明: 有免费额度，DeepSeek-V3 / Qwen3-Embedding / bge-reranker 均可免费使用 │
# │    兼容: 火山方舟也兼容，如需切换只需改 ARK_BASE_URL 和 API Key         │
# ├──────────────────────────────────────────────────────────────────────┤
# │ 2. TAVILY_API_KEY  (必须申请)                                       │
# │    平台: Tavily                                                     │
# │    链接: https://tavily.com                                          │
# │    用途: 联网搜索 (查天气、新闻、实时信息)                              │
# │    说明: 有免费额度 (1000次/月)                                       │
# ├──────────────────────────────────────────────────────────────────────┤
# │ 3. OSS_ACCESS_KEY + OSS_SECRET_KEY  (必须申请)                      │
# │    平台: 阿里云 RAM (访问控制)                                        │
# │    链接: https://ram.console.aliyun.com/manage/ak                    │
# │    用途: 对象存储 (音频文件、用户上传文件)                              │
# │    说明: 需先开通 OSS 服务并创建 Bucket                               │
# ├──────────────────────────────────────────────────────────────────────┤
# │ 4. LANGFUSE_PUBLIC_KEY + LANGFUSE_SECRET_KEY  (可选)                │
# │    平台: Langfuse                                                   │
# │    链接: https://cloud.langfuse.com                                  │
# │    用途: LLM 链路追踪、性能监控                                       │
# │    说明: 不填则自动禁用，不影响功能                                    │
# ├──────────────────────────────────────────────────────────────────────┤
# │ 5. MILVUS_TOKEN  (仅云端模式需要)                                    │
# │    平台: Zilliz Cloud                                               │
# │    链接: https://zilliz.com                                          │
# │    用途: 云端向量数据库 (VECTOR_STORE_PROVIDER=cloud 时)              │
# │    说明: 本地模式 (local) 不需要                                      │
# ├──────────────────────────────────────────────────────────────────────┤
# │ 6. NEO4J_PASSWORD  (云端 AuraDB 时需要)                              │
# │    平台: Neo4j AuraDB                                               │
# │    链接: https://neo4j.com/product/auradb/                           │
# │    用途: 云端图谱数据库 (GRAPH_STORE_PROVIDER=cloud 时)               │
# │    说明: 本地模式不需要                                               │
# ├──────────────────────────────────────────────────────────────────────┤
# │ 7. REDIS_PASSWORD  (云 Redis 时需要)                                 │
# │    平台: 阿里云/腾讯云 Redis                                          │
# │    链接: https://www.aliyun.com/product/redis                        │
# │    用途: 云端缓存 (CACHE_PROVIDER=cloud 时)                          │
# │    说明: 本地模式不需要                                               │
# └──────────────────────────────────────────────────────────────────────┘
#
# JWT_SECRET_KEY 无需申请，自行生成:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"


# ============================================================
# 配置项 (复制到 .env.local 或 .env.prod 后填写真实值)
# ============================================================

# --- LLM (硅基流动 SiliconFlow) ---
# 硅基流动: ARK_BASE_URL=https://api.siliconflow.cn/v1  (默认推荐，免费 embedding/rerank)
# 火山方舟: ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3  (备选)
# 两个平台均为 OpenAI 兼容 API，切换只需改 base_url + API Key
ARK_API_KEY=
ARK_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560

# --- Milvus (向量数据库) ---
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_COLLECTION_FOOD=Food_List
MILVUS_COLLECTION_MEMORY=User_Memory

# --- Neo4j (知识图谱) ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuscockpit

# --- Redis (缓存 + 限流 + PubSub) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_PASSWORD=
REDIS_DB=0

# --- RabbitMQ (任务队列) ---
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- MySQL (用户数据 + 审计日志) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_USER=root
MYSQL_PASSWORD=nexuscockpit
MYSQL_DATABASE=nexus_cockpit

# --- Tavily (联网搜索) ---
TAVILY_API_KEY=

# --- Langfuse (LLM 链路追踪) — 可选 ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- JWT 认证 ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 车辆总线 ---
VEHICLE_ADAPTER=mock

# --- ASR / TTS / 声纹 模型路径 ---
FUNASR_MODEL_PATH=./models/asr/sensevoice
CAM_MODEL_PATH=./models/sv/cam_plus
COSYVOICE_MODEL_PATH=./models/tts/cosyvoice
LOCAL_LLM_MODEL_PATH=./models/llm/qwen
USE_LOCAL_LLM=false

# --- 说话人验证音频 ---
SPEAKER_ENROLL_DIR=./assets/speaker/enroll_wav
SPEAKER_USERS_DIR=./assets/speaker/users

# --- 数据目录 ---
FOOD_DATA_DIR=./data/food
KNOWLEDGE_DATA_DIR=./data/knowledge
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/temp

# --- 服务器 ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# --- 语义缓存 ---
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600

# --- 双模式部署开关 ---
VECTOR_STORE_PROVIDER=local
GRAPH_STORE_PROVIDER=local
CACHE_PROVIDER=local
RERANKER_PROVIDER=local
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- 阿里云 OSS (对象存储) ---
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET_NAME=
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
OSS_PUBLIC_BASE_URL=
